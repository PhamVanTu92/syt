# =============================================================
# SOYTE — Environment Variables Example
# Copy to .env and fill in your values
# =============================================================

# ---- Database -----------------------------------------------
DATABASE_URL="postgresql://admin:password@localhost:5432/suckhuoethudo_db?schema=public"

# ---- JWT ----------------------------------------------------
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_REFRESH_EXPIRES_IN="30d"

# ---- Server -------------------------------------------------
API_PORT=3001
API_PREFIX="api/v2"
NODE_ENV="development"

# ---- CORS ---------------------------------------------------
ALLOWED_ORIGINS="http://localhost:5174,https://suckhoethudo.vn,https://admin.suckhoethudo.vn"

# ---- Frontend URL -------------------------------------------
FRONTEND_URL="http://localhost:5174"

# ---- Email (SMTP) -------------------------------------------
EMAIL_HOST="smtp.example.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER="your_email@example.com"
EMAIL_PASS="your_password"
EMAIL_FROM="Sở Y Tế Hà Nội <noreply@suckhoethudo.vn>"

# ---- Upload -------------------------------------------------
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DEST="uploads"

# ---- Rate Limiting ------------------------------------------
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL_SECONDS=900
AUTH_THROTTLE_LIMIT=20

# ---- Frontend (Vite) ----------------------------------------
VITE_API_URL="http://localhost:3001/api/v2"
VITE_PUBLIC_URL="http://localhost:5174"
VITE_API_V2_MODULES="auth"

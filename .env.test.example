# ─── TEST environment config ──────────────────────────────────────────────────
# Copy file này thành .env.test rồi điền giá trị thực
# .env.test KHÔNG được commit vào git

# DB restore từ golive
TEST_DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@host.docker.internal:35432/suckhuoethudo_dev?schema=public"

# JWT secrets riêng cho test (khác golive để token không dùng lẫn)
TEST_JWT_SECRET="change-this-test-jwt-secret-min-32-chars"
TEST_JWT_REFRESH_SECRET="change-this-test-refresh-secret-min-32-chars"

# URLs
TEST_ALLOWED_ORIGINS="http://YOUR_SERVER_IP:3004"
TEST_FRONTEND_URL="http://YOUR_SERVER_IP:3004"
TEST_VITE_API_URL="http://YOUR_SERVER_IP:3003/api/v2"
TEST_VITE_PUBLIC_URL="http://YOUR_SERVER_IP:3004"

# Email (để trống = log ra console, không gửi thật)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Soyte Test <noreply@test.local>"
